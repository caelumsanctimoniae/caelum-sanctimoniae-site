---
import '@fortawesome/fontawesome-free/css/all.min.css';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- POISTA MYÖHEMMIN, KUN FONTIT SELF-HOSTATAAN -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Alegreya:wght@400;500;700&family=Cormorant+Garamond:wght@400;500;600;700&family=EB+Garamond:wght@400;500;600;700&family=Cinzel:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- POISTA MYÖHEMMIN, KUN FONTIT SELF-HOSTATAAN -->

    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Caelum Sanctimoniae</title>
    <meta
      name="description"
      content="Official website of Caelum Sanctimoniae, a Finnish melodic blackened metal project."
    />
  </head>

  <body>
    <main class="site">
      <header class="header">
        <a
          class="logo-link"
          href="#home"
          data-scroll-target="home"
          aria-label="Caelum Sanctimoniae home"
        >
          <img
            src="/images/caelum-logo.png"
            alt="Caelum Sanctimoniae"
            class="logo"
          />
        </a>

        <nav class="nav" aria-label="Main navigation">
          <a href="#home" data-scroll-target="home">Home</a>
          <a href="#about" data-scroll-target="about">About</a>
          <a href="#music" data-scroll-target="music">Music</a>
        </nav>

        <div class="socials" aria-label="Social links">
          <a
            href="https://www.instagram.com/caelumsanctimoniae"
            aria-label="Instagram"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-instagram"></i>
          </a>

          <a
            href="https://www.youtube.com/@CaelumSanctimoniae"
            aria-label="YouTube"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-youtube"></i>
          </a>

          <a
            href="https://open.spotify.com/artist/7IlLu895PeUQNvSUoBZHti"
            aria-label="Spotify"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-spotify"></i>
          </a>

          <a
            href="https://www.tiktok.com/@caelum.sanctimoniae"
            aria-label="TikTok"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-tiktok"></i>
          </a>

          <a
            href="https://www.facebook.com/caelumsanctimoniae"
            aria-label="Facebook"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-facebook-f"></i>
          </a>
        </div>
      </header>

      <section id="home" class="hero">
        <div class="hero-content">
          <p class="eyebrow">blackened.death.darkened.truth</p>
          <h1>Hollow Crowns of the False Seraphim</h1>
          <p class="subtitle">
            Finnish melodic blackened metal — false divinity, ruined belief,
            and the self that remains.
          </p>

          <div class="hero-actions">
            <a
              class="button primary"
              href="https://push.fm/fl/iis2qjsf"
              target="_blank"
              rel="noopener noreferrer"
            >
              Listen Now
            </a>

            <a
              class="button secondary"
              href="#about"
              data-scroll-target="about"
            >
              Enter the Ruins
            </a>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-inner">
          <h2 id="about">About</h2>
          <p>
            Caelum Sanctimoniae is a melodic blackened metal project from Finland,
            founded in 2025 by Morveth, Alpha Nihili.
          </p>
          <p>
            The music draws from Scandinavian black metal foundations, blackened
            death metal intensity and concept-driven storytelling.
          </p>
        </div>
      </section>

      <section class="section section-dark">
        <div class="section-inner">
          <h2 id="music">Music</h2>

          <article class="release-card">
            <div>
              <p class="release-label">Debut album</p>
              <h3>Hollow Crowns of the False Seraphim</h3>
              <p>
                A concept album about false crowns, divine collapse, transformation
                and the solitary self left standing after the old world falls.
              </p>
            </div>

            <a
              class="button primary"
              href="https://push.fm/fl/iis2qjsf"
              target="_blank"
              rel="noopener noreferrer"
            >
              Listen
            </a>
          </article>
        </div>
      </section>

      <footer class="footer">
        <div class="footer-inner">
          <p class="footer-mark">Caelum Sanctimoniae</p>
          <p class="footer-text">
            Finnish melodic blackened metal — Goblins' Den Studios.
          </p>

          <div class="footer-socials" aria-label="Footer social links">
            <a
              href="https://www.instagram.com/caelumsanctimoniae"
              aria-label="Instagram"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-instagram"></i>
            </a>

            <a
              href="https://www.youtube.com/@CaelumSanctimoniae"
              aria-label="YouTube"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-youtube"></i>
            </a>

            <a
              href="https://open.spotify.com/artist/7IlLu895PeUQNvSUoBZHti"
              aria-label="Spotify"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-spotify"></i>
            </a>

            <a
              href="https://www.tiktok.com/@caelum.sanctimoniae"
              aria-label="TikTok"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-tiktok"></i>
            </a>

            <a
              href="https://www.facebook.com/caelumsanctimoniae"
              aria-label="Facebook"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-facebook-f"></i>
            </a>
          </div>
        </div>
      </footer>
    </main>

    <script is:inline>
      document.addEventListener('click', (event) => {
        const link = event.target.closest('a[data-scroll-target]');

        if (!link) return;

        event.preventDefault();

        const targetId = link.getAttribute('data-scroll-target');
        const hash = link.getAttribute('href');
        const target = document.getElementById(targetId);
        const header = document.querySelector('.header');

        if (!target) return;

        const headerHeight = header ? header.getBoundingClientRect().height : 0;
        const extraSpace = window.innerWidth <= 860 ? 18 : 24;
        const offset = headerHeight + extraSpace;

        const targetPosition =
          target.getBoundingClientRect().top + window.scrollY - offset;

        window.scrollTo({
          top: Math.max(0, targetPosition),
          behavior: 'smooth',
        });

        if (hash) {
          history.pushState(null, '', hash);
        }
      });
    </script>
  </body>
</html>
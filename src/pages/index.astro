---
import '@fortawesome/fontawesome-free/css/all.min.css';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- POISTA MYÖHEMMIN, KUN FONTIT SELF-HOSTATAAN -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Alegreya:wght@400;500;700&family=Cormorant+Garamond:wght@400;500;600;700&family=EB+Garamond:wght@400;500;600;700&family=Cinzel:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- POISTA MYÖHEMMIN, KUN FONTIT SELF-HOSTATAAN -->

    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Caelum Sanctimoniae</title>
    <meta
      name="description"
      content="Official website of Caelum Sanctimoniae, a Finnish melodic blackened metal project."
    />
  </head>

  <body>
    <main class="site">
      <header class="header">
        <a
          class="logo-link"
          href="#home"
          data-scroll-target="home"
          aria-label="Caelum Sanctimoniae home"
        >
          <img
            src="/images/caelum-logo.png"
            alt="Caelum Sanctimoniae"
            class="logo"
          />
        </a>

<nav class="nav" aria-label="Main navigation">
  <a href="#home" data-scroll-target="home">Home</a>
  <a href="#about" data-scroll-target="about">About</a>
  <a href="#music" data-scroll-target="music">Music</a>
  <a href="#news" data-scroll-target="news">News</a>
</nav>

        <div class="socials" aria-label="Social links">
          <a
            href="https://www.instagram.com/caelumsanctimoniae"
            aria-label="Instagram"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-instagram"></i>
          </a>

          <a
            href="https://www.youtube.com/@CaelumSanctimoniae"
            aria-label="YouTube"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-youtube"></i>
          </a>

          <a
            href="https://open.spotify.com/artist/7IlLu895PeUQNvSUoBZHti"
            aria-label="Spotify"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-spotify"></i>
          </a>

          <a
            href="https://www.tiktok.com/@caelum.sanctimoniae"
            aria-label="TikTok"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-tiktok"></i>
          </a>

          <a
            href="https://www.facebook.com/caelumsanctimoniae"
            aria-label="Facebook"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-facebook-f"></i>
          </a>
        </div>
      </header>

      <section id="home" class="hero">
        <div class="hero-content">
          <p class="eyebrow">blackened.death.darkened.truth</p>
                    <p class="subtitle">
            Debut Album
          </p>
          <h1>Hollow Crowns of the False Seraphim</h1>


          <div class="hero-actions">
            <a
              class="button primary"
              href="https://push.fm/fl/iis2qjsf"
              target="_blank"
              rel="noopener noreferrer"
            >
              Listen Now
            </a>

            <a
              class="button secondary"
              href="#about"
              data-scroll-target="about"
            >
              Enter the Ruins
            </a>
          </div>
        </div>
      </section>

<section class="section">
  <div class="section-inner about-layout">
    <div class="about-copy">
      <h2 id="about">About</h2>
      <p>
        Caelum Sanctimoniae is a Finnish melodic blackened metal project founded
        in 2025 by Morveth, Alpha Nihili. The music draws from Scandinavian metal,
        blackened death metal intensity and atmospheric composition, with emphasis
        on structured songwriting, layered guitar work and narrative cohesion.
      </p>
      <p>
        The debut album, Hollow Crowns of the False Seraphim, is a concept-driven
        release exploring consciousness, transformation and the dismantling of
        inherited truths, false divinities and imposed systems of belief.
      </p>
      <p>
        Work is currently underway on the follow-up album, At the Ruins of the New
        Dawn, which continues the story of The Pale and turns toward the aftermath
        of liberation: isolation, memory, consequence and the burden of a world
        built solely from the self.
      </p>
    </div>

    <figure class="about-portrait">
      <img
        src="/images/morveth.png"
        alt="Morveth, Alpha Nihili of Caelum Sanctimoniae"
      />
      <figcaption>
        Morveth, Alpha Nihili
      </figcaption>
    </figure>
  </div>
</section>

     <section class="section section-dark">
  <div class="section-inner">
    <h2 id="music">Music</h2>

    <div class="release-list">
      <article class="release-card">
        <div class="release-info">
          <p class="release-label">Debut album</p>
          <h3>Hollow Crowns of the False Seraphim</h3>
          <p>
            A concept album about false crowns, divine collapse, transformation
            and the solitary self left standing after the old world falls.
          </p>
        </div>

        <div class="release-side">
          <img
            src="/images/hollow-crowns-cover.png"
            alt="Hollow Crowns of the False Seraphim album cover"
            class="release-cover"
          />

          <a
            class="button primary"
            href="https://push.fm/fl/iis2qjsf"
            target="_blank"
            rel="noopener noreferrer"
          >
            Listen
          </a>
        </div>
      </article>

      <article class="release-card release-card-upcoming">
        <div class="release-info">
          <p class="release-label">Upcoming album</p>
          <h3>At the Ruins of the New Dawn</h3>
          <p>
            The follow-up album continues the story of The Pale and turns toward
            the aftermath of liberation: isolation, memory, consequence and the
            burden of a world built solely from the self.
          </p>
        </div>

        <div class="release-side">
          <img
            src="/images/ruins-cover.png"
            alt="At the Ruins of the New Dawn album cover"
            class="release-cover"
          />

          <span class="button secondary button-disabled">
            Coming 2027
          </span>
        </div>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-inner">
    <h2 id="news">News</h2>

    <div class="news-list">

      <article class="news-card">
        <p class="news-date">April 2026</p>
        <h3>Heikki Saari to perform drums on the upcoming album</h3>
        <p>
          The upcoming Caelum Sanctimoniae album will feature drums performed by
          Heikki Saari (Finntroll, Crownshift), bringing a new physical dimension to the project’s next
          chapter.
        </p>
      </article>

      <article class="news-card">
        <p class="news-date">February 2026</p>
        <h3>At the Ruins of the New Dawn in progress</h3>
        <p>
          Work continues on the follow-up album to Hollow Crowns of the False
          Seraphim. The new record expands the story of The Pale and turns toward
          consequence, isolation, memory and collapse.
        </p>
      </article>

      <article class="news-card">
        <p class="news-date">November 2025</p>
        <h3>Hollow Crowns of the False Seraphim released</h3>
        <p>
          The debut full-length album is now available. The record follows a
          metaphysical narrative of false divinity, imposed belief and the self
          that remains after inherited truths collapse.
        </p>
      </article>
    </div>
  </div>
</section>

      <footer class="footer">
        <div class="footer-inner">
          <p class="footer-mark">Caelum Sanctimoniae</p>

          <p class="footer-contact">
  <a href="mailto:contact@caelumsanctimoniae.com">
    contact@caelumsanctimoniae.com
  </a>
</p>


          <div class="footer-socials" aria-label="Footer social links">
            <a
              href="https://www.instagram.com/caelumsanctimoniae"
              aria-label="Instagram"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-instagram"></i>
            </a>

            <a
              href="https://www.youtube.com/@CaelumSanctimoniae"
              aria-label="YouTube"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-youtube"></i>
            </a>

            <a
              href="https://open.spotify.com/artist/7IlLu895PeUQNvSUoBZHti"
              aria-label="Spotify"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-spotify"></i>
            </a>

            <a
              href="https://www.tiktok.com/@caelum.sanctimoniae"
              aria-label="TikTok"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-tiktok"></i>
            </a>

            <a
              href="https://www.facebook.com/caelumsanctimoniae"
              aria-label="Facebook"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="fa-brands fa-facebook-f"></i>
            </a>
          </div>
        </div>
      </footer>
    </main>

    <script is:inline>
      document.addEventListener('click', (event) => {
        const link = event.target.closest('a[data-scroll-target]');

        if (!link) return;

        event.preventDefault();

        const targetId = link.getAttribute('data-scroll-target');
        const hash = link.getAttribute('href');
        const target = document.getElementById(targetId);
        const header = document.querySelector('.header');

        if (!target) return;

        const headerHeight = header ? header.getBoundingClientRect().height : 0;
        const extraSpace = window.innerWidth <= 860 ? 18 : 24;
        const offset = headerHeight + extraSpace;

        const targetPosition =
          target.getBoundingClientRect().top + window.scrollY - offset;

        window.scrollTo({
          top: Math.max(0, targetPosition),
          behavior: 'smooth',
        });

        if (hash) {
          history.pushState(null, '', hash);
        }
      });
    </script>
  </body>
</html>